<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout principal dashboard — écran unique 1280×480
    Remplace la navigation par onglets.
    Deux rangées :
      • Haut  : carte "Paramètres de conduite" (Mode | Regen | ADAS)
      • Bas   : carte CLIMAT (gauche) + carte ALERTES (droite)

    Tipografia centralizzata: dimens.xml + styles.xml (TextAppearance.MG4.* / Widget.MG4.DashButton).
    I pulsanti usano l'autosize (riempiono la casella per la massima leggibilità).
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/dash_bg"
    android:padding="12dp">

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!--  CARTE : Paramètres de conduite                                   -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:orientation="vertical"
        android:background="@drawable/bg_card_rounded"
        android:layout_marginBottom="10dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/card_drive"
            android:textAppearance="@style/TextAppearance.MG4.Overline"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="7dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/dash_border" />

        <!-- 3 colonnes : Mode | Regen | ADAS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:padding="10dp">

            <!-- ── Section Mode de conduite ───────────────────────────── -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_section_rounded"
                android:padding="9dp"
                android:layout_marginEnd="5dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/drive_section_mode"
                    android:textAppearance="@style/TextAppearance.MG4.Overline"
                    android:paddingBottom="5dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/dash_border"
                    android:layout_marginBottom="5dp" />

                <!-- Grille 2×2 : ECO / NORMAL / SPORT / SNOW -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="3dp">

                        <Button
                            android:id="@+id/btn_eco"
                            style="@style/Widget.MG4.DashButton"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:layout_marginBottom="3dp"
                            android:text="@string/drive_eco" />

                        <Button
                            android:id="@+id/btn_sport"
                            style="@style/Widget.MG4.DashButton"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:text="@string/drive_sport" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="3dp">

                        <Button
                            android:id="@+id/btn_normal"
                            style="@style/Widget.MG4.DashButton"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:layout_marginBottom="3dp"
                            android:text="@string/drive_normal" />

                        <Button
                            android:id="@+id/btn_snow"
                            style="@style/Widget.MG4.DashButton"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:text="@string/drive_snow" />

                    </LinearLayout>

                </LinearLayout>

                <!-- CUSTOM pleine largeur -->
                <Button
                    android:id="@+id/btn_custom"
                    style="@style/Widget.MG4.DashButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="@string/drive_custom"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp" />

                <!-- Économie d'énergie — bouton toggle sous Custom (masqué par défaut) -->
                <Button
                    android:id="@+id/btn_energy_saving"
                    style="@style/Widget.MG4.DashButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="@string/drive_energy_saving"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- ── Section Régénération ────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/section_regen"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_section_rounded"
                android:padding="9dp"
                android:layout_marginStart="5dp"
                android:layout_marginEnd="5dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/drive_section_regen"
                    android:textAppearance="@style/TextAppearance.MG4.Overline"
                    android:paddingBottom="5dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/dash_border"
                    android:layout_marginBottom="5dp" />

                <!-- Grille 2×3 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="3dp">

                        <Button
                            android:id="@+id/btn_regen_off"
                            style="@style/Widget.MG4.DashButton"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:layout_marginBottom="3dp"
                            android:text="@string/regen_off" />

                        <Button
                            android:id="@+id/btn_regen_medium"
                            style="@style/Widget.MG4.DashButton"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:layout_marginBottom="3dp"
                            android:text="@string/regen_medium" />

                        <Button
                            android:id="@+id/btn_regen_adaptive"
                            style="@style/Widget.MG4.DashButton"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:text="@string/regen_adaptive_short" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="3dp">

                        <Button
                            android:id="@+id/btn_regen_low"
                            style="@style/Widget.MG4.DashButton"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:layout_marginBottom="3dp"
                            android:text="@string/regen_low" />

                        <Button
                            android:id="@+id/btn_regen_high"
                            style="@style/Widget.MG4.DashButton"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:layout_marginBottom="3dp"
                            android:text="@string/regen_high" />

                        <Button
                            android:id="@+id/btn_regen_one_pedal"
                            style="@style/Widget.MG4.DashButton"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:text="@string/regen_one_pedal_short" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- ── Section ADAS ────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_section_rounded"
                android:padding="9dp"
                android:layout_marginStart="5dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ADAS"
                    android:textAppearance="@style/TextAppearance.MG4.Overline"
                    android:paddingBottom="5dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/dash_border"
                    android:layout_marginBottom="5dp" />

                <!-- SWI133/SWI132 : OFF / LIM.MANUEL / LIM.AUTO / ACC / ICA  (2 rangées) -->
                <LinearLayout
                    android:id="@+id/adas_group_swi133"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <!-- Rangée 1 : Off / Lim. Manuel / Lim. Auto -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:layout_marginBottom="3dp">

                        <Button
                            android:id="@+id/btn_adas_off"
                            style="@style/Widget.MG4.DashButton"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginEnd="3dp"
                            android:text="@string/adas_off" />

                        <Button
                            android:id="@+id/btn_adas_limiteur"
                            style="@style/Widget.MG4.DashButton"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginStart="3dp"
                            android:layout_marginEnd="3dp"
                            android:text="@string/adas_limiteur_short" />

                        <Button
                            android:id="@+id/btn_adas_auto"
                            style="@style/Widget.MG4.DashButton"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginStart="3dp"
                            android:text="@string/adas_auto" />

                    </LinearLayout>

                    <!-- Rangée 2 : ACC / ICA -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btn_adas_acc"
                            style="@style/Widget.MG4.DashButton"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginEnd="3dp"
                            android:text="@string/adas_acc" />

                        <Button
                            android:id="@+id/btn_adas_ica"
                            style="@style/Widget.MG4.DashButton"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginStart="3dp"
                            android:layout_marginEnd="3dp"
                            android:text="@string/adas_ica" />

                        <!-- Spacer pour aligner sur 3 colonnes -->
                        <View
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginStart="3dp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- SWI68/69/131/165 : OFF / LIM.MANUEL / LIM.AUTO / ACC / TJA  (2 rangées) -->
                <LinearLayout
                    android:id="@+id/adas_group_swi68"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <!-- Rangée 1 : Off / Lim. Manuel / Lim. Auto -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:layout_marginBottom="3dp">

                        <Button
                            android:id="@+id/btn_swi68_off"
                            style="@style/Widget.MG4.DashButton"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginEnd="3dp"
                            android:text="@string/adas_off" />

                        <Button
                            android:id="@+id/btn_swi68_lim"
                            style="@style/Widget.MG4.DashButton"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginStart="3dp"
                            android:layout_marginEnd="3dp"
                            android:text="@string/adas_limiteur_short" />

                        <Button
                            android:id="@+id/btn_swi68_auto"
                            style="@style/Widget.MG4.DashButton"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginStart="3dp"
                            android:text="@string/adas_auto" />

                    </LinearLayout>

                    <!-- Rangée 2 : ACC / TJA -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btn_swi68_acc"
                            style="@style/Widget.MG4.DashButton"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginEnd="3dp"
                            android:text="@string/adas_acc" />

                        <Button
                            android:id="@+id/btn_swi68_tja"
                            style="@style/Widget.MG4.DashButton"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginStart="3dp"
                            android:layout_marginEnd="3dp"
                            android:text="@string/adas_tja" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginStart="3dp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!--  LIGNE BASSE : Climat (gauche) + Alertes (droite)                 -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- ── Carte CLIMAT (masquée en SWI69 — pas de sièges/volant chauffant) -->
        <LinearLayout
            android:id="@+id/climate_card"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.15"
            android:orientation="vertical"
            android:background="@drawable/bg_card_rounded"
            android:layout_marginEnd="5dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/card_climate"
                android:textAppearance="@style/TextAppearance.MG4.Overline"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="7dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/dash_border" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:padding="10dp">

                <!-- Volant chauffant -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="0.65"
                    android:orientation="vertical"
                    android:background="@drawable/bg_section_rounded"
                    android:padding="9dp"
                    android:layout_marginEnd="5dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/climate_steering_heat"
                        android:textAppearance="@style/TextAppearance.MG4.Overline"
                        android:paddingBottom="5dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/dash_border"
                        android:layout_marginBottom="5dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:gravity="center">

                        <Switch
                            android:id="@+id/switch_steering_heat"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Siège gauche -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_section_rounded"
                    android:padding="9dp"
                    android:layout_marginStart="5dp"
                    android:layout_marginEnd="5dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/climate_seat_left"
                        android:textAppearance="@style/TextAppearance.MG4.Overline"
                        android:paddingBottom="5dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/dash_border"
                        android:layout_marginBottom="5dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="2dp">

                            <Button
                                android:id="@+id/btn_seat_left_0"
                                style="@style/Widget.MG4.DashButton"
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout_weight="1"
                                android:layout_marginBottom="2dp"
                                android:text="@string/climate_off" />

                            <Button
                                android:id="@+id/btn_seat_left_2"
                                style="@style/Widget.MG4.DashButton"
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout_weight="1"
                                android:text="@string/climate_level_2" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="2dp">

                            <Button
                                android:id="@+id/btn_seat_left_1"
                                style="@style/Widget.MG4.DashButton"
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout_weight="1"
                                android:layout_marginBottom="2dp"
                                android:text="@string/climate_level_1" />

                            <Button
                                android:id="@+id/btn_seat_left_3"
                                style="@style/Widget.MG4.DashButton"
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout_weight="1"
                                android:text="@string/climate_level_3" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

                <!-- Siège droit -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_section_rounded"
                    android:padding="9dp"
                    android:layout_marginStart="5dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/climate_seat_right"
                        android:textAppearance="@style/TextAppearance.MG4.Overline"
                        android:paddingBottom="5dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/dash_border"
                        android:layout_marginBottom="5dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="2dp">

                            <Button
                                android:id="@+id/btn_seat_right_0"
                                style="@style/Widget.MG4.DashButton"
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout_weight="1"
                                android:layout_marginBottom="2dp"
                                android:text="@string/climate_off" />

                            <Button
                                android:id="@+id/btn_seat_right_2"
                                style="@style/Widget.MG4.DashButton"
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout_weight="1"
                                android:text="@string/climate_level_2" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="2dp">

                            <Button
                                android:id="@+id/btn_seat_right_1"
                                style="@style/Widget.MG4.DashButton"
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout_weight="1"
                                android:layout_marginBottom="2dp"
                                android:text="@string/climate_level_1" />

                            <Button
                                android:id="@+id/btn_seat_right_3"
                                style="@style/Widget.MG4.DashButton"
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout_weight="1"
                                android:text="@string/climate_level_3" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- ── Carte SÉCURITÉ & ALERTES ─────────────────────────────── -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/bg_card_rounded"
            android:layout_marginStart="5dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/card_alerts"
                android:textAppearance="@style/TextAppearance.MG4.Overline"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="7dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/dash_border" />

            <!-- 2 colonnes : Sécurité (gauche) | Alertes (droite) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:padding="8dp">

                <!-- ── Colonne gauche : AEB ── -->
                <LinearLayout
                    android:id="@+id/aeb_group"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_section_rounded"
                    android:padding="9dp"
                    android:layout_marginEnd="5dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/adas_section_aeb"
                        android:textAppearance="@style/TextAppearance.MG4.Overline"
                        android:paddingBottom="5dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/dash_border"
                        android:layout_marginBottom="6dp" />

                    <!-- Toggle AEB ON/OFF -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/adas_aeb_switch"
                            android:textAppearance="@style/TextAppearance.MG4.Label" />

                        <Switch
                            android:id="@+id/switch_aeb"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                    </LinearLayout>

                    <!-- Mode AEB : Alerte / Alerte + Freinage -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btn_aeb_alarm"
                            style="@style/Widget.MG4.DashButton"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="44dp"
                            android:layout_marginEnd="3dp"
                            android:text="@string/adas_aeb_alarm" />

                        <Button
                            android:id="@+id/btn_aeb_alarm_brake"
                            style="@style/Widget.MG4.DashButton"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="44dp"
                            android:layout_marginStart="3dp"
                            android:text="@string/adas_aeb_alarm_brake" />

                    </LinearLayout>

                </LinearLayout>

                <!-- ── Colonne droite : Alertes sonores ── -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_section_rounded"
                    android:padding="9dp"
                    android:layout_marginStart="5dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/adas_section_sounds"
                        android:textAppearance="@style/TextAppearance.MG4.Overline"
                        android:paddingBottom="5dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/dash_border"
                        android:layout_marginBottom="6dp" />

                    <!-- 2 colonnes : TSR à gauche, autres alertes à droite -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal">

                        <!-- Colonne gauche : TSR -->
                        <LinearLayout
                            android:id="@+id/section_tsr"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:visibility="gone">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/adas_tsr"
                                android:textAppearance="@style/TextAppearance.MG4.Label" />

                            <Switch
                                android:id="@+id/switch_tsr"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />

                        </LinearLayout>

                        <!-- Séparateur vertical -->
                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="@color/dash_border"
                            android:layout_marginStart="6dp"
                            android:layout_marginEnd="6dp" />

                        <!-- Colonne droite : alertes spécifiques au firmware -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_vertical">

                            <!-- SWI133 : Survitesse + Chgt vitesse -->
                            <LinearLayout
                                android:id="@+id/alerts_group_swi133"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:visibility="gone">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:layout_marginBottom="6dp">

                                    <TextView
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="@string/adas_overspeed_alarm"
                                        android:textAppearance="@style/TextAppearance.MG4.Label" />

                                    <Switch
                                        android:id="@+id/switch_overspeed"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content" />

                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">

                                    <TextView
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="@string/adas_speed_limit_tone"
                                        android:textAppearance="@style/TextAppearance.MG4.Label" />

                                    <Switch
                                        android:id="@+id/switch_speed_tone"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content" />

                                </LinearLayout>

                            </LinearLayout>

                            <!-- SWI68/69/131 : Alerte sonore -->
                            <LinearLayout
                                android:id="@+id/alerts_group_swi68"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:visibility="gone">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">

                                    <TextView
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="@string/adas_sound_warning"
                                        android:textAppearance="@style/TextAppearance.MG4.Label" />

                                    <Switch
                                        android:id="@+id/switch_sound_warning"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content" />

                                </LinearLayout>

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
